<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.nuecoo.viewmodel.CollectionFragmentViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.fragment.CollectionFragment">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_collection_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="36dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/bg_default_button"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="36dp"
            android:paddingVertical="8dp"
            android:text="@string/text_collection_no"
            android:textColor="@color/main_border"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <android.widget.CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/btn_collection_type"
            app:layout_constraintBottom_toBottomOf="@id/btn_collection_type"
            app:layout_constraintStart_toEndOf="@id/btn_collection_type"
            android:id="@+id/cb_collect"
            android:layout_marginStart="6dp"
            android:paddingStart="6dp"
            android:text="@string/text_collection_check_text"
            android:textColor="@color/main_border"
            android:button="@drawable/cb_collected_selector"
            android:buttonTint="@null"
            android:background="@null"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_collection"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/img_collection_background"
            android:paddingHorizontal="28dp"
            android:paddingVertical="28dp"
            app:layout_constraintBottom_toTopOf="@id/rv_cookie_type"
            app:layout_constraintTop_toBottomOf="@id/btn_collection_type" />


        <androidx.recyclerview.widget.RecyclerView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingVertical="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:id="@+id/rv_cookie_type"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_collection_cookie_type"
            android:layout_marginHorizontal="12dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>